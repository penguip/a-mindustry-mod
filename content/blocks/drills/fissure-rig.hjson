requirements: [
  yttrium/50
  silicon/75
  osmium/65
  iron/15
]
consumes: {
  liquid: entropy/0.1
  liquids: {
    liquids: [
      water/0.5
    ]
    optional: true
    boooster: true
  }
}
liquidBoostIntensity: 1.2
liquidCapacity: 15
